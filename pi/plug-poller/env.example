# Supabase
SUPABASE_URL=https://plwchuzidrjgyuepwdcl.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBsd2NodXppZHJqZ3l1ZXB3ZGNsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTk0ODUyOTIsImV4cCI6MjA3NTA2MTI5Mn0.p9giTnFOK-b0NqrB4ZqN-3CJEaAqMNy-KYvRZ6P_qS0

# Tuya plug (from `python -m tinytuya wizard`)
TUYA_DEVICE_ID=
TUYA_LOCAL_KEY=
TUYA_IP=
TUYA_VERSION=3.4

# Behaviour
POLL_INTERVAL_SEC=10
STATE_REPORT_INTERVAL_SEC=30
RESTART_OFF_SECONDS=8
# Skip commands older than this (runaway-loop protection after outage)
MAX_COMMAND_AGE_SEC=300

# Dead-man's switch — pluggen får aldrig fastna i off-läge.
# Om den läses som OFF i mer än STUCK_OFF_MAX_SEC utan pending-kommando och
# utan färskt manuellt 'off' (inom MANUAL_OFF_GRACE_SEC) forcerar pollern ON
# lokalt via tinytuya. Skyddar mot avbrutna restarts och nätverksglitcher.
STUCK_OFF_MAX_SEC=120
MANUAL_OFF_GRACE_SEC=600

# Watchdog
# Set to true only if you want the Pi watchdog to queue restarts.
# Default false — the cloud rapt-watchdog edge function is authoritative.
WATCHDOG_ENABLED=false
WATCHDOG_INTERVAL_SEC=300
WATCHDOG_STALE_MIN=31
WATCHDOG_COOLDOWN_MIN=20